POSTGRES_USER=careeragent
POSTGRES_PASSWORD=careeragent
POSTGRES_DB=careeragent
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Docker Compose reads .env automatically; the backend also loads repo-root .env
# when run locally. Shell/Docker environment variables override values here.
DATABASE_URL=postgresql+psycopg2://careeragent:careeragent@db:5432/careeragent
# For a backend run locally outside Docker, use localhost instead of Docker's db hostname:
# DATABASE_URL=postgresql+psycopg2://careeragent:careeragent@localhost:5432/careeragent
LOCAL_DATABASE_URL=postgresql+psycopg2://careeragent:careeragent@localhost:5432/careeragent
BACKEND_PORT=8000
FRONTEND_PORT=3000
ENABLE_SAMPLE_JOBS=false
AI_PROVIDER=mock
AI_ALLOW_EXTERNAL_CALLS=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_KEEP_OPEN_SECONDS=900
PLAYWRIGHT_USE_XVFB=true
PLAYWRIGHT_SLOW_MO_MS=0
